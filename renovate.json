{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "America/Argentina/Cordoba",
  "schedule": ["at any time"],
  "labels": ["renovate"],
  "prConcurrentLimit": 10,
  "flux": {
    "fileMatch": ["(^|/)bootstrap/kubernetes/.+\\.ya?ml$"]
  },
  "kubernetes": {
    "fileMatch": ["(^|/)bootstrap/kubernetes/.+\\.ya?ml$"]
  },
  "ignorePaths": [
    "**/secret-*.yaml"
  ],
  "packageRules": [
    {
      "description": "Patch and digest updates: auto-merge",
      "matchUpdateTypes": ["patch", "digest"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Media stack: group all updates into a single PR",
      "matchPackageNames": [
        "jellyfin/jellyfin",
        "lscr.io/linuxserver/sonarr",
        "lscr.io/linuxserver/radarr",
        "linuxserver/bazarr",
        "ghcr.io/seerr-team/seerr",
        "maintainerr/maintainerr",
        "lscr.io/linuxserver/transmission",
        "crazymax/diun"
      ],
      "groupName": "media stack",
      "automerge": false
    },
    {
      "description": "Security components: always require manual review",
      "matchPackageNames": ["authelia"],
      "automerge": false,
      "labels": ["security", "renovate"]
    },
    {
      "description": "Infrastructure components: require manual review",
      "matchPackageNames": ["traefik", "cert-manager", "metallb"],
      "automerge": false,
      "labels": ["infrastructure", "renovate"]
    },
    {
      "description": "Major versions: require manual approval from Dependency Dashboard",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "dependencyDashboardApproval": true,
      "labels": ["breaking-change", "renovate"]
    }
  ]
}
